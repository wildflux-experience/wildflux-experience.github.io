---
const { items = [] } = Astro.props;
---

<nav class="home-menu" aria-label="Menu principal">
  {
    items.map((item, index) => (
      <>
        <a class="home-menu-item" href={item.href}>{item.label}</a>
        {index < items.length - 1 && <span class="home-menu-separator" aria-hidden="true">|</span>}
      </>
    ))
  }
</nav>
