---
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../config/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/template-page.css';
---

<BaseLayout
  title={`Posters - ${site.title}`}
  description="Posters crees a partir des photos de Blackfish Creation"
>
  <main class="page posters-page">
    <PageHeader
      title="Posters"
      description="Une selection de posters crees a partir des series photo."
      backHref="/"
      backLabel="Retour"
    />

    <section class="poster-placeholder" aria-label="Posters a venir">
      <p>Les premiers posters seront ajoutes ici.</p>
    </section>
  </main>
</BaseLayout>
